# SUPABASE ENVIRONMENT VARIABLES
# ==============================
#
# INSTRUÇÕES PARA OBTER OS VALORES:
# 1. Acesse https://app.supabase.com
# 2. Faça login com sua conta Supabase
# 3. Selecione seu projeto
# 4. Vá para: Settings > API (no menu esquerdo)
# 5. Copie os valores abaixo
#
# ==============================

# URL do seu projeto Supabase
# Exemplo: https://hwcvxchacxdqwftqxvks.supabase.co
VITE_SUPABASE_URL=https://seu-projeto-id.supabase.co

# Chave pública ANON
# Localizada em Settings > API > "Project API keys" > "anon"
# Começa com: eyJhbGciOi...
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Variáveis de fallback (pode usar os mesmos valores acima)
SUPABASE_URL=https://seu-projeto-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ID do projeto (extrair da URL)
# Exemplo: hwcvxchacxdqwftqxvks
VITE_SUPABASE_PROJECT_ID=seu-projeto-id
